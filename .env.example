# Copy to .env and edit. All values are optional; defaults shown.

# --- what to track ---
HEX=3f232b                       # D-LZFN (Goodyear Blimp Europe)
BLIMP_NAME=Goodyear Blimp (D-LZFN)
POLL_INTERVAL=15                 # seconds between upstream polls (be a good citizen)
PORT=8080
HISTORY_MAX=720                  # track points kept for the map trail (~3h @ 15s)

# --- notifications: set ONE (or more). Unset = log-only dry run. ---

# ntfy (recommended). Subscribe to the same topic in the ntfy phone/desktop app.
# Use a long, unguessable topic if you use the public ntfy.sh server.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=                    # bearer token, only for a protected/self-hosted ntfy

# Telegram (alternative): create a bot via @BotFather, get your chat id.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Generic webhook (alternative): receives JSON {title,message,priority,tags,url}
# WEBHOOK_URL=
